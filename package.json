{
  "name": "ascenta",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "turbo dev",
    "dev:marketing": "turbo dev --filter=@ascenta/marketing",
    "dev:platform": "turbo dev --filter=@ascenta/platform",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
