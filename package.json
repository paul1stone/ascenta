{
  "name": "ascenta",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "turbo dev",
    "dev:marketing": "turbo dev --filter=@ascenta/marketing",
    "dev:platform": "turbo dev --filter=@ascenta/platform",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:seed": "pnpm --filter @ascenta/db db:seed",
    "db:seed-grow": "pnpm --filter @ascenta/db exec npx tsx ../../scripts/seed-grow.ts",
    "db:seed-strategy": "pnpm --filter @ascenta/db exec npx tsx ../../scripts/seed-strategy.ts"
  },
  "devDependencies": {
    "turbo": "^2"
  }
}
