# MongoDB Atlas connection string (required)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ascenta?appName=Cluster0

# AI provider keys (at least one required; OpenAI needed for RAG/embeddings)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Email (optional — Resend transactional email)
RESEND_API_KEY=

# App URL (defaults to http://localhost:3000)
APP_URL=http://localhost:3051

# Vercel cron authorization (optional)
CRON_SECRET=

# Demo notification recipient (optional, defaults to demos@ascenta.ai)
INTERNAL_DEMO_EMAIL=
